<html>
<head>
  <title>Pokedex</title>
  <link rel="stylesheet" href="/styleSheets/main.css">
</head>

<body>
  <main>
    <div id="side-panel">


      <ul>
        
        <li><a class="all" href="#">All</a></li>
        <% it.pokiTypes.forEach(function(type){%>
        <li><a class="" href="/<%=type%>"><%=type%></a></li>
        <% }) %>
      </ul>
    </div>
    <div id="right-panel">
    <% it.pokiesData.forEach(function(pokiData){ %>

      <div class="card">
        <div class="img-container">
          <img src="<%=pokiData.imgUrl%>"
            alt="<%=pokiData.name%> image">
        </div>
        <div class="name-type-container">
          <span class="name"><%=pokiData.name%></span>
          <div class="types">
            <% pokiData.types.forEach(function(type){ %>
            <span class="type <%=type%>"> <%=type%></span>
            <%})%>
          </div>
        </div>
        <table class="stats">
          <% pokiData.stats.forEach(function(stat){ %>
            <tr>
               <td><%=stat.name%></td>
               <td><%=stat.base_stat%></td>
            </tr>
          <% })%>
        </table>
      </div>
   <%}) %>
    </div>
  </main>
</body>

</html>